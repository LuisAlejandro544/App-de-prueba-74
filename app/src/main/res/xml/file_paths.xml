<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Internal files directory (context.filesDir) -->
    <files-path name="internal_files" path="." />
    
    <!-- Internal cache directory (context.cacheDir) -->
    <cache-path name="internal_cache" path="." />
    
    <!-- External storage files directory (context.getExternalFilesDir(null)) -->
    <external-files-path name="external_files" path="." />
    
    <!-- External storage cache directory (context.getExternalCacheDir()) -->
    <external-cache-path name="external_cache" path="." />
    
    <!-- External root storage directory -->
    <external-path name="external_root" path="." />
</paths>
